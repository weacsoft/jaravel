# ===========================================
# Jaravel 环境变量示例（对齐 Laravel .env）
# 复制为 .env 并按需修改；Spring Boot 通过 application.yml 读取
# ===========================================

APP_NAME=Jaravel
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080

# 数据库
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=jaravel
DB_USERNAME=root
DB_PASSWORD=

# 缓存
CACHE_DRIVER=array

# Session
SESSION_DRIVER=memory

# 队列
QUEUE_CONNECTION=sync

# JWT
JWT_SECRET=jaravel-secret-key-change-in-production-must-be-32-bytes
JWT_TTL=3600
